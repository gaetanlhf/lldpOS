#!/bin/bash

echo "=== Interfaces ==="
for iface in /sys/class/net/*; do
    name=$(basename "$iface")
    state=$(cat "$iface/operstate" 2>/dev/null || echo "unknown")
    mac=$(cat "$iface/address" 2>/dev/null || echo "N/A")
    speed=$(cat "$iface/speed" 2>/dev/null) && speed="${speed} Mb/s" || speed="N/A"
    ips=$(ip -4 addr show "$name" 2>/dev/null | awk '/inet / {print $2}' | tr '\n' ' ')
    ips6=$(ip -6 addr show "$name" 2>/dev/null | awk '/inet6 / && !/fe80/ {print $2}' | tr '\n' ' ')
    [ "$name" = "lo" ] && speed="-"
    printf "  %-14s  %-6s  %-18s  %-10s  %s\n" "$name" "$state" "$mac" "$speed" "${ips}${ips6}"
done

echo ""
echo "=== Default Route ==="
defroute=$(ip -4 route show default 2>/dev/null)
if [ -n "$defroute" ]; then
    echo "  $defroute"
else
    echo "  No default route"
fi

echo ""
echo "=== DNS ==="
if [ -f /etc/resolv.conf ]; then
    grep "^nameserver" /etc/resolv.conf | while read -r line; do
        echo "  $line"
    done
    grep -q "^nameserver" /etc/resolv.conf || echo "  No nameservers configured"
else
    echo "  /etc/resolv.conf not found"
fi
echo ""
